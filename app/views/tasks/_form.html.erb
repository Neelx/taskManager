<div class="task-form-card" id="task-form-card">
  <%= form_with model: task, id: "task-form" do |f| %>
    <% if task.errors.any? %>
      <div class="form-errors" id="task-form-errors">
        <% task.errors.full_messages.each do |msg| %>
          <div class="form-error-item">⚠ <%= msg %></div>
        <% end %>
      </div>
    <% end %>

    <div class="form-group">
      <%= f.label :title, "Task Title", class: "form-label" %>
      <%= f.text_field :title,
          class: "form-control #{'input-error' if task.errors[:title].any?}",
          placeholder: "What needs to be done?",
          id: "task-title",
          required: true,
          autofocus: true %>
    </div>

    <div class="form-group">
      <%= f.label :description, "Description", class: "form-label" %>
      <span class="form-label-optional">Optional</span>
      <%= f.text_area :description,
          class: "form-control form-textarea",
          placeholder: "Add more details about this task...",
          id: "task-description",
          rows: 4 %>
    </div>

    <div class="form-row">
      <div class="form-group form-col">
        <%= f.label :priority, "Priority", class: "form-label" %>
        <%= f.select :priority,
            [["🟢 Low", "low"], ["🟡 Medium", "medium"], ["🔴 High", "high"]],
            {},
            { class: "form-control form-select", id: "task-priority" } %>
      </div>

      <div class="form-group form-col">
        <%= f.label :due_date, "Due Date", class: "form-label" %>
        <span class="form-label-optional">Optional</span>
        <%= f.date_field :due_date, class: "form-control", id: "task-due-date" %>
      </div>
    </div>

    <% if task.persisted? %>
      <div class="form-group">
        <label class="form-label checkbox-label">
          <%= f.check_box :completed, class: "form-checkbox", id: "task-completed" %>
          <span>Mark as completed</span>
        </label>
      </div>
    <% end %>

    <div class="form-actions">
      <%= f.submit task.persisted? ? "Save Changes" : "Create Task",
          class: "btn btn-primary", id: "btn-submit-task" %>
      <%= link_to "Cancel", tasks_path, class: "btn btn-ghost", id: "btn-cancel-task" %>
    </div>
  <% end %>
</div>
