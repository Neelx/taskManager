<% content_for :title, @task.completed? ? "[Done] #{@task.title}" : @task.title %>
<% content_for :page_title, "Task Details" %>

<div class="task-detail" id="task-detail-<%= @task.id %>">
  <div class="detail-card">
    <div class="detail-header">
      <div class="detail-header-left">
        <span class="badge badge-<%= @task.priority %> badge-lg"><%= @task.priority_label %> Priority</span>
        <span class="status-pill status-<%= @task.status_label.downcase.gsub(' ', '-') %>"><%= @task.status_label %></span>
      </div>
      <div class="detail-header-right">
        <%= link_to "✏ Edit", edit_task_path(@task), class: "btn btn-secondary", id: "btn-edit-detail" %>
        <%= button_to "✕ Delete", task_path(@task), method: :delete, class: "btn btn-danger",
            id: "btn-delete-detail",
            form: { data: { turbo_confirm: "Delete this task? This cannot be undone." } } %>
      </div>
    </div>

    <h1 class="detail-title <%= 'strikethrough' if @task.completed? %>"><%= @task.title %></h1>

    <% if @task.description.present? %>
      <p class="detail-description"><%= @task.description %></p>
    <% end %>

    <div class="detail-meta">
      <div class="meta-item">
        <span class="meta-label">Due Date</span>
        <span class="meta-value <%= @task.overdue? ? 'text-danger' : '' %>">
          <%= @task.due_date.present? ? @task.due_date.strftime("%B %d, %Y") : "No due date" %>
        </span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Created</span>
        <span class="meta-value"><%= @task.created_at.strftime("%B %d, %Y") %></span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Last Updated</span>
        <span class="meta-value"><%= @task.updated_at.strftime("%B %d, %Y") %></span>
      </div>
    </div>

    <div class="detail-actions">
      <%= button_to @task.completed? ? "↩ Mark Incomplete" : "✓ Mark Complete",
          toggle_complete_task_path(@task), method: :patch,
          class: "btn #{@task.completed? ? 'btn-secondary' : 'btn-success'}",
          id: "btn-toggle-detail",
          form: { data: { turbo: false } } %>
      <%= link_to "← Back to Tasks", tasks_path, class: "btn btn-ghost", id: "btn-back-detail" %>
    </div>
  </div>
</div>
