<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="Taskmaster — Organize your work, crush your goals.">
    <title><%= content_for?(:title) ? "#{yield(:title)} · Taskmaster" : "Taskmaster" %></title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="<%= logged_in? ? 'app-layout' : 'auth-layout' %>">
    <% if logged_in? %>
      <!-- Sidebar -->
      <aside class="sidebar" id="sidebar">
        <div class="sidebar-brand">
          <div class="brand-icon">✓</div>
          <span class="brand-name">Taskmaster</span>
        </div>

        <nav class="sidebar-nav">
          <a href="<%= root_path %>" class="nav-item <%= controller_name == 'dashboard' ? 'active' : '' %>" id="nav-dashboard">
            <span class="nav-icon">⊞</span>
            <span class="nav-label">Dashboard</span>
          </a>

          <a href="<%= tasks_path %>" class="nav-item <%= controller_name == 'tasks' && params[:filter].blank? ? 'active' : '' %>" id="nav-all-tasks">
            <span class="nav-icon">☑</span>
            <span class="nav-label">All Tasks</span>
            <% if @nav_counts[:total].to_i > 0 %>
              <span class="nav-badge"><%= @nav_counts[:total] %></span>
            <% end %>
          </a>

          <a href="<%= tasks_path(filter: 'pending') %>" class="nav-item <%= params[:filter] == 'pending' ? 'active' : '' %>" id="nav-pending">
            <span class="nav-icon">◷</span>
            <span class="nav-label">Pending</span>
            <% if @nav_counts[:pending].to_i > 0 %>
              <span class="nav-badge nav-badge-warn"><%= @nav_counts[:pending] %></span>
            <% end %>
          </a>

          <a href="<%= tasks_path(filter: 'today') %>" class="nav-item <%= params[:filter] == 'today' ? 'active' : '' %>" id="nav-today">
            <span class="nav-icon">📅</span>
            <span class="nav-label">Due Today</span>
            <% if @nav_counts[:today].to_i > 0 %>
              <span class="nav-badge nav-badge-warn"><%= @nav_counts[:today] %></span>
            <% end %>
          </a>

          <a href="<%= tasks_path(filter: 'overdue') %>" class="nav-item <%= params[:filter] == 'overdue' ? 'active' : '' %>" id="nav-overdue">
            <span class="nav-icon">⚠</span>
            <span class="nav-label">Overdue</span>
            <% if @nav_counts[:overdue].to_i > 0 %>
              <span class="nav-badge nav-badge-danger"><%= @nav_counts[:overdue] %></span>
            <% end %>
          </a>

          <a href="<%= tasks_path(filter: 'high') %>" class="nav-item <%= params[:filter] == 'high' ? 'active' : '' %>" id="nav-high">
            <span class="nav-icon">🔥</span>
            <span class="nav-label">High Priority</span>
            <% if @nav_counts[:high].to_i > 0 %>
              <span class="nav-badge nav-badge-danger"><%= @nav_counts[:high] %></span>
            <% end %>
          </a>

          <a href="<%= tasks_path(filter: 'completed') %>" class="nav-item <%= params[:filter] == 'completed' ? 'active' : '' %>" id="nav-completed">
            <span class="nav-icon">✔</span>
            <span class="nav-label">Completed</span>
            <% if @nav_counts[:completed].to_i > 0 %>
              <span class="nav-badge nav-badge-success"><%= @nav_counts[:completed] %></span>
            <% end %>
          </a>
        </nav>

        <div class="sidebar-footer">
          <div class="user-card">
            <div class="user-avatar"><%= current_user.initials %></div>
            <div class="user-info">
              <span class="user-name"><%= current_user.name %></span>
              <span class="user-email"><%= current_user.email %></span>
            </div>
          </div>
          <%= button_to "Sign out", logout_path, method: :delete, class: "btn-signout", id: "btn-signout" %>
        </div>
      </aside>

      <!-- Main content -->
      <main class="main-content">
        <div class="topbar">
          <div class="topbar-left">
            <div class="topbar-title"><%= content_for?(:page_title) ? yield(:page_title) : "Dashboard" %></div>
            <% if @nav_counts[:overdue].to_i > 0 %>
              <span class="topbar-alert">
                ⚠ <%= @nav_counts[:overdue] %> overdue <%= "task".pluralize(@nav_counts[:overdue]) %>
              </span>
            <% end %>
          </div>
          <div class="topbar-actions">
            <%= link_to "+ New Task", new_task_path, class: "btn btn-primary", id: "btn-new-task" %>
          </div>
        </div>

        <% if notice %>
          <div class="flash flash-notice" id="flash-notice" role="alert">
            <span>✓</span> <%= notice %>
          </div>
        <% end %>
        <% if alert %>
          <div class="flash flash-alert" id="flash-alert" role="alert">
            <span>⚠</span> <%= alert %>
          </div>
        <% end %>

        <div class="page-body">
          <%= yield %>
        </div>
      </main>

    <% else %>
      <% if notice %>
        <div class="flash flash-notice auth-flash" id="flash-notice" role="alert"><%= notice %></div>
      <% end %>
      <% if alert %>
        <div class="flash flash-alert auth-flash" id="flash-alert" role="alert"><%= alert %></div>
      <% end %>
      <%= yield %>
    <% end %>
  </body>
</html>
